{
  "name": "stim-packages-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "format": "prettier --check package.json pnpm-workspace.yaml \"scripts/**/*.mjs\"",
    "format:write": "prettier --write package.json pnpm-workspace.yaml \"scripts/**/*.mjs\"",
    "postinstall": "node ./scripts/postinstall.mjs",
    "precommit": "node ./scripts/precommit.mjs",
    "guard": "node ./scripts/guard.mjs"
  },
  "devDependencies": {
    "@stim-io/shared": "workspace:*",
    "prettier": "3.8.2"
  }
}
