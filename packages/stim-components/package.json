{
  "name": "@stim-io/stim-components",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stim-io/stim-components.git",
    "directory": "packages/stim-components"
  },
  "homepage": "https://github.com/stim-io/stim-components",
  "bugs": {
    "url": "https://github.com/stim-io/stim-components/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./tokens.css": "./dist/tokens/index.css",
    "./themes/light/common.css": "./dist/themes/light/common.css",
    "./themes/light/chromium.css": "./dist/themes/light/chromium.css",
    "./themes/light/webkit.css": "./dist/themes/light/webkit.css",
    "./themes/dark/common.css": "./dist/themes/dark/common.css",
    "./themes/dark/chromium.css": "./dist/themes/dark/chromium.css",
    "./themes/dark/webkit.css": "./dist/themes/dark/webkit.css"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && vite build && vue-tsc -p tsconfig.build.json --emitDeclarationOnly && node ./scripts/copy-theme.mjs",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
