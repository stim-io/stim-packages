{
  "name": "@stim-io/components",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stim-io/stim-packages.git",
    "directory": "packages/components"
  },
  "homepage": "https://github.com/stim-io/stim-packages",
  "bugs": {
    "url": "https://github.com/stim-io/stim-packages/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/*": "./dist/styles/*"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "lint": "node ./scripts/lint.mjs",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "payload": "node ./scripts/payload.mjs",
    "release": "node ./scripts/release.mjs"
  },
  "peerDependencies": {
    "vue": "3.5.32"
  },
  "dependencies": {
    "@stim-io/grid-layout": "workspace:*"
  },
  "devDependencies": {
    "@stim-io/shared": "workspace:*",
    "@vitejs/plugin-vue": "6.0.6",
    "cac": "7.0.0",
    "postcss-scss": "4.0.9",
    "sass": "1.99.0",
    "stylelint": "17.9.1",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-scss": "7.0.0",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vue": "3.5.32",
    "vue-tsc": "3.2.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
