    "release": "node ./scripts/release.mjs"
  },
  "dependencies": {
    "execa": "9.6.0",
    "fast-glob": "3.3.3"
  },
  "devDependencies": {
    "cac": "7.0.0",
    "typescript": "6.0.2",
    "vue": "3.5.32"
  },
  "publishConfig": {
