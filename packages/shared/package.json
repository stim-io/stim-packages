{
  "name": "@stim-io/shared",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stim-io/stim-packages.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/stim-io/stim-packages",
  "bugs": {
