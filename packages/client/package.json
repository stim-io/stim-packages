{
  "name": "@stim-io/client",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stim-io/stim-packages.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/stim-io/stim-packages",
  "bugs": {
    "url": "https://github.com/stim-io/stim-packages/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "node ./scripts/generate.mjs && pnpm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.91.0",
    "typescript": "6.0.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
